// To test when functions don't return anything
fizzbuzz = || {
    for i in 1..=100 {
        if i % 15 == 0 {
            println("Fizzbuzz")
        } else if i % 3 == 0 {
            println("Fizz")
        } else if i % 5 == 0 {
            println("Buzz")
        } else {
            println(i)
        }
    }
}

main = || -> I64 {
    fizzbuzz()
    return 0
}
